# Production environment contract for docker-compose.production.yml.
#
#   cp .env.production.example .env.production   # on the deploy host
#
# Fill every value marked REQUIRED. Never commit the filled file, and never
# reuse the developer .env here: any key that has been in a working tree is
# considered exposed and must be rotated before it appears below.

# --- Database (REQUIRED) -----------------------------------------------------
# POSTGRES_HOST/PORT are overridden in-compose to the in-network db service;
# they are listed here only for host-side tooling.
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=advisor
POSTGRES_USER=advisor
# REQUIRED. Generate a strong value, e.g. `openssl rand -base64 32`.
POSTGRES_PASSWORD=

# Fail startup instead of silently falling back to the read-only Excel
# workbook when PostgreSQL is unreachable. Always true in production.
REQUIRE_POSTGRES=true

# --- Agent LLM routing -------------------------------------------------------
# At least one provider key is REQUIRED, otherwise the agent runs without its
# reasoning core. Candidates are tried in order: OpenAI, OpenRouter, Mistral.
# The agent's main reasoning core is gpt-4o-mini.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1
# Optional override for the main agent model. Leave empty to keep gpt-4o-mini.
AGENT_MAIN_LLM_MODEL=
# Optional Mistral fallback model override.
FALLBACK_LLM_MODEL=

# --- Public agent endpoint limits -------------------------------------------
# The agent endpoints are unauthenticated, so these bound the cost and abuse
# surface. Raise deliberately, not by default.
AGENT_MAX_MESSAGE_CHARS=2000
AGENT_RATE_LIMIT_REQUESTS=20
AGENT_RATE_LIMIT_WINDOW_SECONDS=60
AGENT_MAX_SESSIONS=5000

# --- Embeddings (optional; ingestion only) -----------------------------------
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1

# --- Data paths (container-relative; leave as-is) ----------------------------
DATASET_DIR=data/dataset
PROCESSED_DIR=data/processed

# --- Observability (optional) ------------------------------------------------
# Fail-open: with the keys absent the agent runs behind a no-op observer.
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO

# --- Edge --------------------------------------------------------------------
# The production topology is same-origin behind nginx, so cross-origin access
# stays disabled. Set only if the frontend is served from another origin.
ADVISOR_CORS_ORIGINS=
# Loopback by default: the host nginx terminates TLS and proxies here. Set
# HTTP_BIND=0.0.0.0 only when this stack is the outermost edge.
HTTP_BIND=127.0.0.1
HTTP_PORT=8080
