# Use one of the member slugs documented in ai-logs/README.md.
TEAM_MEMBER=

# Provider credentials are optional until a task explicitly requires them.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Planned advisor client interface; not every variable is consumed yet.
NEXT_PUBLIC_ADVISOR_MODE=mock
NEXT_PUBLIC_ADVISOR_API_URL=http://127.0.0.1:8000
# Role selection
MAIN_LLM_PROVIDER=
MAIN_LLM_MODEL=
EXTRACTION_LLM_PROVIDER=
EXTRACTION_LLM_MODEL=
FALLBACK_LLM_PROVIDER=
FALLBACK_LLM_MODEL=
JUDGE_LLM_PROVIDER=
JUDGE_LLM_MODEL=

# Provider connectivity
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=
MISTRAL_API_KEY=
MISTRAL_BASE_URL=

# Optional dotenv path
MODEL_ENV_FILE=

# --- Local data platform (PostgreSQL + pgvector) ---------------------------
# Discrete parts (used when DATABASE_URL is empty). Do not commit real values.
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=advisor
POSTGRES_USER=advisor
POSTGRES_PASSWORD=
# Full connection string; when set it overrides the discrete POSTGRES_* parts.
DATABASE_URL=

# Ingestion source (read-only business data) and intermediate output.
DATASET_DIR=data/dataset
PROCESSED_DIR=data/processed

# Knowledge-base embeddings (API). Leave EMBEDDING_API_KEY empty to store
# chunks with NULL embeddings (local run is never blocked).
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1

# Comma-separated browser origins allowed to call the advisor API.
# Empty = no cross-origin access (frontend integration is deferred).
ADVISOR_CORS_ORIGINS=
