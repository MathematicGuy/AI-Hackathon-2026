# Local development contract. Production uses a separate file on the deploy
# host: see .env.production.example and docker-compose.production.yml.
TEAM_MEMBER=

# Agent LLM routing. Candidates are tried in order: OpenAI, OpenRouter,
# Mistral. The agent's main reasoning core is gpt-4o-mini; AGENT_MAIN_LLM_MODEL
# overrides it. DEFAULT_MODEL belongs to the M1 rig, not the agent.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1
AGENT_MAIN_LLM_MODEL=
FALLBACK_LLM_MODEL=

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Port 55432 matches the loopback override in infra/docker-compose.dev.yml.
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_DB=advisor
POSTGRES_USER=advisor
POSTGRES_PASSWORD=
# Leave false locally so a missing database falls back to the Excel workbook;
# production sets it true to fail fast instead of serving parallel data.
REQUIRE_POSTGRES=false
DATASET_DIR=data/dataset
PROCESSED_DIR=data/processed

# Embeddings (ingestion only). EMBEDDING_DIM is the name the code reads.
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1

# Public agent endpoint limits. Defaults apply when unset.
AGENT_MAX_MESSAGE_CHARS=2000
AGENT_RATE_LIMIT_REQUESTS=20
AGENT_RATE_LIMIT_WINDOW_SECONDS=60
AGENT_MAX_SESSIONS=5000

LOG_LEVEL=INFO

# Frontend development only. `next dev` serves the app without nginx in front,
# so it proxies /api/* to this origin (see frontend/next.config.ts). Production
# ignores it: nginx routes /api/ to the backend on the same origin, and the
# browser never learns a backend hostname.
BACKEND_ORIGIN=http://127.0.0.1:8000

# Optional. Only needed when the frontend and backend are served from different
# origins. The production topology is same-origin, so leave this empty there.
ADVISOR_CORS_ORIGINS=

# Where docker-compose.production.yml publishes its nginx. The default binds to
# loopback because the host nginx terminates TLS and proxies to it. Set
# HTTP_BIND=0.0.0.0 only when the container is the outermost edge.
HTTP_BIND=127.0.0.1
HTTP_PORT=8080
