TEAM_MEMBER="luu-thien-viet-cuong"

# Choose one or both providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
DEFAULT_MODEL=deepseek/deepseek-v4-flash

# Logging
LOG_LEVEL=INFO

# AI Hook Logging (set by instructor)
AI_LOG_DIR=.ai-log

# Models & embedding (Phase 11)
GUARD_LLM_MODEL=gpt-5.4-nano
EXTRACTION_LLM_MODEL=mistral-medium-latest # switched from deepseek/deepseek-v4-flash (persistent upstream 429) for a clean eval baseline
JUDGE_LLM_MODEL=mistral-large-latest
FEATURE_GEN_LLM_MODEL=mistral-small-2603
# FALLBACK_LLM_MODEL=openai/gpt-oss-120b
FALLBACK_LLM_MODEL=mistral-medium-latest


MAX_OUTPUT_TOKENS=2048
EMBEDDING_MODEL=jina-embeddings-v3
EMBEDDING_DIMENSIONS=1024
USE_LOCAL_EMBEDDINGS=false
JINA_API_KEY=


# Document services (bật khi chạy docker-compose.tools.yml; để trống = tắt) - optional
DOC_SERVICE_TIMEOUT=900
MINERU_API_KEY=

LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=

POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_DB=advisor
POSTGRES_USER=advisor
POSTGRES_PASSWORD=
DATASET_DIR=data/dataset
PROCESSED_DIR=data/processed
EMBEDDING_API_KEY=

# Frontend development only. `next dev` serves the app without nginx in front,
# so it proxies /api/* to this origin (see frontend/next.config.ts). Production
# ignores it: nginx routes /api/ to the backend on the same origin, and the
# browser never learns a backend hostname.
BACKEND_ORIGIN=http://127.0.0.1:8000

# Optional. Only needed when the frontend and backend are served from different
# origins. The production topology is same-origin, so leave this empty there.
ADVISOR_CORS_ORIGINS=

# Where docker-compose.production.yml publishes its nginx. The default binds to
# loopback because the host nginx terminates TLS and proxies to it. Set
# HTTP_BIND=0.0.0.0 only when the container is the outermost edge.
HTTP_BIND=127.0.0.1
HTTP_PORT=8080
