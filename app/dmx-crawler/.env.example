# SQLite is the zero-dependency local default. PostgreSQL is supported by the
# supplied SQL migration (and by the optional psycopg adapter).
DMX_DATABASE_URL=sqlite:///data/dmx.db
DMX_SITE_BASE_URL=https://www.dienmayxanh.com
DMX_USER_AGENT=DMXCrawler/0.1 (+respectful research; contact: replace-me@example.invalid)
DMX_MIN_REQUEST_INTERVAL_SECONDS=5
DMX_REQUEST_TIMEOUT_SECONDS=30
DMX_MAX_ATTEMPTS=3
DMX_LOCATIONS_FILE=config/locations.yaml
DMX_CATEGORIES_FILE=config/categories.yaml

# PostgreSQL option for `docker compose --profile postgres`:
# DMX_DATABASE_URL=postgresql://dmx:dmx-local-only@postgres:5432/dmx
# POSTGRES_DB=dmx
# POSTGRES_USER=dmx
# POSTGRES_PASSWORD=dmx-local-only

# Match bind-mounted ./data ownership when host UID/GID are not 1000.
LOCAL_UID=1000
LOCAL_GID=1000
